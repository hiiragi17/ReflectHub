# ReflectHub 環境変数サンプル
#
# このファイルをコピーして `.env.local` を作成し、各値を埋めてください:
#   cp .env.example .env.local
#
# 本番では Vercel Dashboard → Settings → Environment Variables に同じキーを登録します。
# NEXT_PUBLIC_ 接頭辞の付くものだけがブラウザに露出します。それ以外はサーバー専用 (秘匿) です。

# ─────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────

# Supabase プロジェクトの URL / anon key。
# Supabase Dashboard → Project Settings → API から取得。
# 公開されても問題ない値 (RLS で保護)。Production / Preview / Development すべてに設定。
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# service_role key。RLS をバイパスするためサーバー専用。絶対に公開しない (NEXT_PUBLIC_ を付けない)。
# Supabase Dashboard → Project Settings → API → service_role から取得。
# Cron ジョブ (/api/cron/daily-reminder) など、ユーザーセッションに紐づかない処理で使用。
# Production / Preview に設定。未設定だと cron が
#   "Service role client requires NEXT_PUBLIC_SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY"
# で失敗する。
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────
# Cron (Vercel Cron / 手動トリガ認証)
# ─────────────────────────────────────────────

# /api/cron/* を保護する Bearer トークン。任意のランダム文字列。
# 例: `openssl rand -hex 32` で生成。
# 手動確認: curl -H "Authorization: Bearer $CRON_SECRET" https://<domain>/api/cron/daily-reminder
CRON_SECRET=your-random-cron-secret

# ─────────────────────────────────────────────
# CSRF
# ─────────────────────────────────────────────

# CSRF トークンの HMAC 署名鍵。16 文字以上必須。サーバー専用。
# 例: `openssl rand -hex 32` で生成。
CSRF_SECRET=your-csrf-hmac-secret-min-16-chars

# ─────────────────────────────────────────────
# Web Push (VAPID)
# ─────────────────────────────────────────────

# VAPID 鍵ペア。`pnpm dlx web-push generate-vapid-keys` で生成。
# 公開鍵はクライアントの購読登録に使うため NEXT_PUBLIC_。秘密鍵はサーバー専用。
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Push の連絡先。mailto: または https URL。未設定時は mailto:noreply@reflecthub.app が使われる。
VAPID_SUBJECT=mailto:you@example.com
